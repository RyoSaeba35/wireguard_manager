<!-- app/views/admin_mailer/password_theft_alert.html.erb -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333;
    }
    .critical {
      background: #dc3545;
      color: white;
      padding: 20px;
      border-radius: 5px;
      margin-bottom: 20px;
    }
    .critical h1 {
      margin: 0 0 10px 0;
      font-size: 24px;
    }
    .critical h2 {
      margin: 0;
      font-size: 18px;
      font-weight: normal;
    }
    .details {
      background: #f8f9fa;
      padding: 15px;
      margin: 15px 0;
      border-radius: 5px;
      border-left: 4px solid #dc3545;
    }
    .details h3 {
      margin-top: 0;
      color: #dc3545;
    }
    .location {
      background: white;
      border-left: 4px solid #dc3545;
      padding: 10px;
      margin: 10px 0;
      border-radius: 3px;
    }
    .actions {
      background: #d4edda;
      border-left: 4px solid #28a745;
      padding: 15px;
      margin: 15px 0;
      border-radius: 5px;
    }
    .actions h3 {
      margin-top: 0;
      color: #28a745;
    }
    ul, ol {
      margin: 10px 0;
      padding-left: 20px;
    }
    .footer {
      margin-top: 30px;
      padding-top: 20px;
      border-top: 1px solid #ddd;
      font-size: 12px;
      color: #666;
    }
  </style>
</head>
<body>
  <div class="critical">
    <h1>🚨 CRITICAL SECURITY ALERT</h1>
    <h2>Password Theft Detected</h2>
  </div>

  <div class="details">
    <h3>Compromised Credentials</h3>
    <p><strong>Username:</strong> <%= @username %></p>
    <p><strong>Client ID:</strong> <%= @client.id %></p>
    <p><strong>Client Type:</strong> <%= @client.class.name %></p>
    <p><strong>Status:</strong> <span style="color: #dc3545; font-weight: bold;">LOCKED</span></p>
    <p><strong>Locked at:</strong> <%= @client.locked_at&.strftime('%Y-%m-%d %H:%M:%S UTC') || 'Just now' %></p>
  </div>

  <div class="details">
    <h3>User Information</h3>
    <% if @user %>
      <p><strong>Email:</strong> <%= @user.email %></p>
      <p><strong>User ID:</strong> <%= @user.id %></p>
      <p><strong>Device:</strong> <%= @device.name %> (<%= @device.platform %>)</p>
      <p><strong>Subscription:</strong> <%= @device.subscription&.name || 'N/A' %></p>
    <% else %>
      <p><em>No user associated (preallocated client)</em></p>
    <% end %>
  </div>

  <div class="details">
    <h3>Suspicious Activity</h3>
    <p><strong>Password used simultaneously from <%= @geolocations.size %> different locations:</strong></p>

    <% @geolocations.each_with_index do |geo, index| %>
      <div class="location">
        <strong>Location <%= index + 1 %>:</strong><br>
        <strong>IP Address:</strong> <%= geo[:ip] %><br>
        <strong>City:</strong> <%= geo[:geo][:city] %><br>
        <strong>Country:</strong> <%= geo[:geo][:country] %> (<%= geo[:geo][:country_code] %>)
      </div>
    <% end %>

    <p style="margin-top: 15px; padding: 10px; background: #fff3cd; border-left: 4px solid #ffc107;">
      ⚠️ <strong>This is physically impossible!</strong> The same password was used from
      <%= @geolocations.map { |g| g[:geo][:country] }.uniq.join(' and ') %> at the same time.
    </p>
  </div>

  <div class="actions">
    <h3>✅ Actions Automatically Taken</h3>
    <ul>
      <li>All connections using <strong><%= @username %></strong> have been terminated immediately</li>
      <li>Client <strong><%= @username %></strong> has been locked and cannot be used</li>
      <li>Password is no longer valid for any connections</li>
      <li>This alert has been sent to administrators</li>
    </ul>
  </div>

  <div class="details">
    <h3>📋 Recommended Next Steps</h3>
    <ol>
      <% if @user %>
        <li><strong>Contact the user:</strong> <%= @user.email %></li>
        <li><strong>Investigate:</strong> Was this legitimate (user traveling abroad) or actual credential theft?</li>
        <li><strong>If legitimate:</strong> Unlock the client and advise the user about multi-country usage</li>
        <li><strong>If theft:</strong> Keep locked, issue new credentials, advise user to change passwords</li>
      <% else %>
        <li>This is a preallocated client (not yet assigned to a user)</li>
        <li>Client will remain locked until manually unlocked by admin</li>
        <li>Consider regenerating this credential if needed</li>
      <% end %>
    </ol>
  </div>

  <div class="footer">
    <p>
      <strong>Time detected:</strong> <%= Time.current.strftime('%Y-%m-%d %H:%M:%S UTC') %><br>
      <strong>Detection system:</strong> ClashApiMonitorJob (sing-box log analysis + geolocation)<br>
      <strong>Server:</strong> <%= @client.try(:server)&.name || 'Unknown' %>
    </p>
    <p>
      This is an automated security alert from Vulcain VPN monitoring system.<br>
      Do not reply to this email. For questions, contact the development team.
    </p>
  </div>
</body>
</html>
