<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f5f5f5;
      color: #1a1a1a;
      padding: 24px;
    }

    .container {
      max-width: 780px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .header {
      background: #ff6e08;
      padding: 24px 32px;
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .header h1 {
      color: #ffffff;
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.3px;
    }

    .header p {
      color: rgba(255,255,255,0.8);
      font-size: 13px;
      margin-top: 2px;
    }

    .body {
      padding: 28px 32px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 24px;
    }

    .info-card {
      background: #f8f8f8;
      border-radius: 8px;
      padding: 14px 16px;
      border-left: 3px solid #ff6e08;
    }

    .info-card .label {
      font-size: 11px;
      font-weight: 600;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }

    .info-card .value {
      font-size: 14px;
      font-weight: 500;
      color: #1a1a1a;
      word-break: break-all;
    }

    .info-card.full {
      grid-column: 1 / -1;
    }

    .user-message {
      background: #fff8f0;
      border: 1px solid #ffd4a8;
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 24px;
    }

    .user-message .label {
      font-size: 11px;
      font-weight: 600;
      color: #cc5500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }

    .user-message p {
      font-size: 14px;
      color: #333;
      line-height: 1.6;
    }

    .log-section h2 {
      font-size: 13px;
      font-weight: 600;
      color: #555;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 12px;
    }

    .log-box {
      background: #0f0a0e;
      border-radius: 8px;
      padding: 20px;
      overflow-x: auto;
    }

    .log-box pre {
      font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
      font-size: 11.5px;
      line-height: 1.65;
      color: #e0e0e0;
      white-space: pre-wrap;
      word-break: break-word;
    }

    /* Colour-code log lines */
    .log-box pre .line-ok     { color: #4caf50; }
    .log-box pre .line-warn   { color: #ff9800; }
    .log-box pre .line-error  { color: #f44336; }
    .log-box pre .line-info   { color: #90caf9; }

    .footer {
      padding: 18px 32px;
      background: #fafafa;
      border-top: 1px solid #eee;
      font-size: 12px;
      color: #999;
      text-align: center;
    }

    .footer a { color: #ff6e08; text-decoration: none; }
  </style>
</head>
<body>
  <div class="container">

    <!-- Header -->
    <div class="header">
      <div>
        <h1>🔧 Diagnostic Report</h1>
        <p>VulcainVPN — received <%= @sent_at %></p>
      </div>
    </div>

    <div class="body">

      <!-- Device / User info -->
      <div class="info-grid">
        <div class="info-card">
          <div class="label">User</div>
          <div class="value"><%= @user_email %></div>
        </div>
        <div class="info-card">
          <div class="label">User ID</div>
          <div class="value">#<%= @user_id %></div>
        </div>
        <div class="info-card">
          <div class="label">Device</div>
          <div class="value"><%= @device_info %></div>
        </div>
        <div class="info-card">
          <div class="label">Android version</div>
          <div class="value"><%= @os_version %></div>
        </div>
        <div class="info-card">
          <div class="label">App version</div>
          <div class="value">v<%= @app_version %></div>
        </div>
        <div class="info-card">
          <div class="label">Sent at</div>
          <div class="value"><%= @sent_at %></div>
        </div>
      </div>

      <!-- User message (only shown if provided) -->
      <% if @user_message.present? %>
      <div class="user-message">
        <div class="label">Message from user</div>
        <p><%= @user_message %></p>
      </div>
      <% end %>

      <!-- Log -->
      <div class="log-section">
        <h2>Diagnostic Log</h2>
        <div class="log-box">
          <pre><%= @log_content %></pre>
        </div>
      </div>

    </div>

    <div class="footer">
      VulcainVPN Support &mdash; <a href="https://www.vulcainvpn.com">vulcainvpn.com</a>
    </div>

  </div>
</body>
</html>
