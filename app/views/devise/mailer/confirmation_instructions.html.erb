<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    .cta-btn:hover {
      background-color: #e65c00;
    }
  </style>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #2c3e50; max-width: 600px; margin: 0 auto; padding: 20px;">
  <!-- Logo -->
  <div style="text-align: center; margin-bottom: 20px;">
    <a href="https://vulcainvpn.com" style="display: inline-block;">
      <% if attachments['Vulcain_VPN_logo_3.png'] %>
        <%= image_tag(
          attachments['Vulcain_VPN_logo_3.png'].url,
          alt: "Vulcain VPN Logo",
          style: "max-width: 200px; height: auto; display: block; margin: 0 auto; border: 0;"
        ) %>
      <% else %>
        <span style="color: #2c3e50; font-weight: bold; font-size: 20px;">Vulcain VPN</span>
      <% end %>
    </a>
  </div>

  <!-- Header -->
  <h1 style="color: #2c3e50; font-family: Arial, sans-serif; text-align: center;">
    Confirm Your Email Address
  </h1>

  <!-- Welcome Message -->
  <p style="font-size: 16px;">
    Welcome <%= @resource.email %>!
  </p>

  <!-- Instructions -->
  <p style="font-size: 16px;">
    You're just one step away from getting started. Please confirm your email address by clicking the button below:
  </p>

  <!-- CTA Button -->
  <p style="text-align: center; margin: 20px 0;">
    <a href="<%= confirmation_url(@resource, confirmation_token: @token) %>"
       class="cta-btn"
       style="background-color: #ff6e08; color: white; padding: 12px 24px; border: none; border-radius: 4px; font-size: 16px; text-decoration: none; display: inline-block; font-family: Arial, sans-serif; transition: background-color 0.3s ease;">
      Confirm My Account
    </a>
  </p>

  <!-- Security Note -->
  <p style="font-size: 14px; color: #7f8c8d;">
    This link will expire in 24 hours for your security.
  </p>

  <!-- Ignore Instruction -->
  <p style="font-size: 16px;">
    If you didn't create an account, you can safely ignore this email.
  </p>

  <!-- Regards -->
  <p style="font-size: 16px;">
    Best regards,<br>
    <strong>The Vulcain VPN Team</strong>
  </p>

  <!-- Footer -->
  <p style="font-size: 12px; color: #7f8c8d; margin-top: 20px; text-align: center;">
    © 2025 Vulcain VPN. All rights reserved.<br>
    <a href="https://www.vulcainvpn.com/privacy" style="color: #7f8c8d; text-decoration: none;">Privacy Policy</a> -
    <a href="https://www.vulcainvpn.com/terms" style="color: #7f8c8d; text-decoration: none;">Terms of Service</a> -
    <a href="https://www.vulcainvpn.com/logging" style="color: #7f8c8d; text-decoration: none;">Logging Policy</a>
  </p>
</body>
</html>
