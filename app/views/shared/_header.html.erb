<header class="header">
  <%= link_to root_path, class: "logo-link" do %>
    <%= image_tag "Vulcain_VPN_logo_4.png", alt: "Vulcain VPN Logo", class: "logo" %>
  <% end %>
  <button class="hamburger" aria-label="Toggle menu">☰</button>
  <nav class="nav-links">
    <% if user_signed_in? %>
      <!-- Show admin links when on admin pages -->
      <% if controller.class.name.start_with?('Admin::') %>
        <%= link_to "📊 Dashboard", admin_dashboard_path, class: current_page?(admin_dashboard_path) ? 'active' : '' %>
        <%= link_to "👥 Users", admin_users_path, class: controller_name == 'users' ? 'active' : '' %>
        <%= link_to "🖥️ Servers", admin_servers_path, class: controller_name == 'servers' ? 'active' : '' %>
        <%= link_to "💎 Plans", admin_plans_path, class: controller_name == 'plans' ? 'active' : '' %>
        <div class="nav-divider"></div>
        <%= link_to "← Back to App", root_path, class: "back-link" %>
      <% else %>
        <!-- Regular user links -->
        <%= link_to "Dashboard", root_path %>
        <%= link_to "Edit Profile", profile_path %>
        <% if current_user.admin? %>
          <%= link_to "⚡ Admin", admin_dashboard_path, class: "admin-badge-link" %>
        <% end %>
      <% end %>
      <%= button_to "Log Out", destroy_user_session_path, method: :delete, class: "logout-btn" %>
    <% else %>
      <a href="<%= new_user_session_path %>" class="login-btn">Log In</a>
    <% end %>
  </nav>
</header>

<style>
  .header {
    background-color: #432923;
    color: white;
    padding: 10px 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 1002;
  }

  .logo {
    height: 60px;
  }

  .logo-link {
    display: flex;
    align-items: center;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-links a,
  .nav-links button {
    color: white;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
    padding: 0.5rem;
    border-radius: 4px;
    transition: background-color 0.2s;
  }

  .nav-links a.active {
    background-color: rgba(155, 89, 182, 0.3);
    font-weight: 600;
  }

  .nav-links a:hover,
  .nav-links button:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .admin-badge-link {
    background: linear-gradient(135deg, #9b59b6, #e74c3c) !important;
    padding: 0.5rem 1rem !important;
    font-weight: 600;
  }

  .back-link {
    color: #95a5a6 !important;
  }

  .nav-divider {
    width: 1px;
    height: 24px;
    background: rgba(255, 255, 255, 0.2);
  }

  .logout-btn {
    color: #e74c3c !important;
  }

  .hamburger {
    display: none;
    cursor: pointer;
    font-size: 1.5rem;
    background: none;
    border: none;
    color: white;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .header {
      padding: 0rem 1rem;
    }

    .nav-links {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 60px;
      left: 0;
      width: 100%;
      background-color: #432923;
      padding: 1rem;
      gap: 0.5rem;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }

    .nav-links.active {
      display: flex;
    }

    .nav-links a,
    .nav-links button {
      font-size: 1rem;
      padding: 0.75rem;
      width: 100%;
      text-align: left;
    }

    .nav-divider {
      width: 100%;
      height: 1px;
    }

    .hamburger {
      display: block;
    }
  }
</style>

<script>
  document.addEventListener('turbo:load', function() {
    const hamburger = document.querySelector('.hamburger');
    const navLinks = document.querySelector('.nav-links');

    if (hamburger && navLinks) {
      hamburger.addEventListener('click', function() {
        navLinks.classList.toggle('active');
      });
    }
  });
</script>
