<%# app/views/admin/servers/_form.html.erb %>
<div class="server-form-wrapper">
  <%= form_with(model: [:admin, @server], local: true, class: "server-form") do |form| %>

    <!-- Error Messages -->
    <% if @server.errors.any? %>
      <div class="alert alert-error">
        <div class="alert-header">
          <span class="alert-icon">⚠️</span>
          <h3 class="alert-title">
            <%= pluralize(@server.errors.count, "error") %> prevented this server from being saved
          </h3>
        </div>
        <ul class="alert-list">
          <% @server.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Form Sections -->
    <div class="form-sections">

      <!-- Basic Information -->
      <div class="form-section">
        <div class="section-header">
          <h3 class="section-title">🖥️ Basic Information</h3>
          <p class="section-description">Server identification and network details</p>
        </div>

        <div class="form-grid">
          <div class="form-group">
            <%= form.label :name, class: "form-label" do %>
              Server Name <span class="required">*</span>
            <% end %>
            <%= form.text_field :name,
                class: "form-control",
                placeholder: "e.g., Paris Server 1",
                required: true %>
          </div>

          <div class="form-group">
            <%= form.label :ip_address, class: "form-label" do %>
              Server IP Address <span class="required">*</span>
            <% end %>
            <%= form.text_field :ip_address,
                class: "form-control",
                placeholder: "e.g., 192.168.1.100",
                required: true %>
            <small class="form-hint">SSH and management IP address</small>
          </div>

          <div class="form-group form-group-checkbox">
            <%= form.check_box :active, class: "form-checkbox", id: "server_active" %>
            <%= form.label :active, class: "checkbox-label" do %>
              <span class="checkbox-text">Server is active and accepting connections</span>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Location Information -->
      <div class="form-section">
        <div class="section-header">
          <h3 class="section-title">🌍 Location Information</h3>
          <p class="section-description">Geographic location for server selection</p>
        </div>

        <div class="form-grid">
          <div class="form-group">
            <%= form.label :location, class: "form-label" do %>
              Location <span class="required">*</span>
            <% end %>
            <%= form.text_field :location,
                class: "form-control",
                placeholder: "e.g., Paris, France",
                required: true %>
          </div>

          <div class="form-group">
            <%= form.label :city, class: "form-label" %>
            <%= form.text_field :city,
                class: "form-control",
                placeholder: "e.g., Paris" %>
          </div>

          <div class="form-group">
            <%= form.label :country_code, class: "form-label" %>
            <%= form.text_field :country_code,
                class: "form-control",
                placeholder: "e.g., FR",
                maxlength: 2 %>
            <small class="form-hint">Two-letter country code (ISO 3166-1 alpha-2)</small>
          </div>

          <div class="form-group">
            <%= form.label :flag, class: "form-label" %>
            <%= form.text_field :flag,
                class: "form-control",
                placeholder: "e.g., 🇫🇷" %>
            <small class="form-hint">Flag emoji for UI display</small>
          </div>

          <div class="form-group">
            <%= form.label :latitude, class: "form-label" %>
            <%= form.number_field :latitude,
                class: "form-control",
                step: 0.0001,
                placeholder: "e.g., 48.8566" %>
          </div>

          <div class="form-group">
            <%= form.label :longitude, class: "form-label" %>
            <%= form.number_field :longitude,
                class: "form-control",
                step: 0.0001,
                placeholder: "e.g., 2.3522" %>
          </div>
        </div>
      </div>

      <!-- Capacity Settings -->
      <div class="form-section">
        <div class="section-header">
          <h3 class="section-title">📊 Capacity & Pooling</h3>
          <p class="section-description">Connection limits and config pool settings</p>
        </div>

        <div class="form-grid">
          <div class="form-group">
            <%= form.label :max_concurrent_connections, class: "form-label" do %>
              Max Concurrent Connections <span class="required">*</span>
            <% end %>
            <%= form.number_field :max_concurrent_connections,
                class: "form-control",
                min: 1,
                max: 1000,
                value: @server.max_concurrent_connections || 225,
                required: true %>
            <small class="form-hint">Maximum number of simultaneous VPN connections (default: 225)</small>
          </div>

          <div class="form-group">
            <%= form.label :config_pool_size, class: "form-label" do %>
              Config Pool Size <span class="required">*</span>
            <% end %>
            <%= form.number_field :config_pool_size,
                class: "form-control",
                min: 100,
                max: 10000,
                value: @server.config_pool_size || 3000,
                required: true %>
            <small class="form-hint">Total number of pre-generated configs (default: 3000)</small>
          </div>
        </div>
      </div>

      <!-- WireGuard Settings -->
      <div class="form-section">
        <div class="section-header">
          <h3 class="section-title">🔐 WireGuard Settings</h3>
          <p class="section-description">WireGuard VPN protocol configuration</p>
        </div>

        <div class="form-grid">
          <div class="form-group">
            <%= form.label :wireguard_server_ip, class: "form-label" do %>
              WireGuard Server IP <span class="required">*</span>
            <% end %>
            <%= form.text_field :wireguard_server_ip,
                class: "form-control",
                placeholder: "e.g., 10.155.0.1",
                required: true %>
            <small class="form-hint">Internal WireGuard interface IP</small>
          </div>

          <div class="form-group">
            <%= form.label :wireguard_port, class: "form-label" %>
            <%= form.number_field :wireguard_port,
                class: "form-control",
                min: 1,
                max: 65535,
                value: @server.wireguard_port || 53050 %>
            <small class="form-hint">Default: 53050</small>
          </div>

          <div class="form-group form-group-full">
            <%= form.label :wireguard_public_key, class: "form-label" %>
            <%= form.text_area :wireguard_public_key,
                class: "form-control form-textarea",
                placeholder: "Public key for WireGuard authentication",
                rows: 2 %>
          </div>
        </div>
      </div>

      <!-- Sing-box Settings -->
      <div class="form-section">
        <div class="section-header">
          <h3 class="section-title">🚀 Sing-box Settings</h3>
          <p class="section-description">Hysteria2 and Shadowsocks protocol configuration</p>
        </div>

        <div class="form-grid">
          <div class="form-group form-group-checkbox">
            <%= form.check_box :singbox_active, class: "form-checkbox", id: "server_singbox_active" %>
            <%= form.label :singbox_active, class: "checkbox-label" do %>
              <span class="checkbox-text">Enable Sing-box (Hysteria2 + Shadowsocks)</span>
            <% end %>
          </div>

          <div class="form-group">
            <%= form.label :singbox_server_name, class: "form-label" %>
            <%= form.text_field :singbox_server_name,
                class: "form-control",
                placeholder: "e.g., example.com" %>
            <small class="form-hint">Server name for TLS (optional)</small>
          </div>

          <div class="form-group">
            <%= form.label :singbox_hysteria2_port, class: "form-label" %>
            <%= form.number_field :singbox_hysteria2_port,
                class: "form-control",
                min: 1,
                max: 65535,
                value: @server.singbox_hysteria2_port || 8443 %>
            <small class="form-hint">Default: 8443</small>
          </div>

          <div class="form-group">
            <%= form.label :singbox_ss_port, class: "form-label" %>
            <%= form.number_field :singbox_ss_port,
                class: "form-control",
                min: 1,
                max: 65535,
                value: @server.singbox_ss_port || 443 %>
            <small class="form-hint">Default: 443</small>
          </div>

          <div class="form-group form-group-full">
            <%= form.label :singbox_salamander_password, class: "form-label" do %>
              Salamander Password
              <% if @server.persisted? %>
                <span class="optional-text">(leave blank to keep current)</span>
              <% end %>
            <% end %>
            <%= form.password_field :singbox_salamander_password,
                class: "form-control",
                placeholder: "Hysteria2 obfuscation password",
                value: "" %>
            <small class="form-hint">Password for Hysteria2 Salamander obfuscation</small>
          </div>

          <div class="form-group form-group-full">
            <%= form.label :singbox_ss_master_password, class: "form-label" do %>
              Shadowsocks Master Password
              <% if @server.persisted? %>
                <span class="optional-text">(leave blank to keep current)</span>
              <% end %>
            <% end %>
            <%= form.password_field :singbox_ss_master_password,
                class: "form-control",
                placeholder: "Shadowsocks master password",
                value: "" %>
            <small class="form-hint">Master password for Shadowsocks encryption</small>
          </div>

          <div class="form-group form-group-full">
            <%= form.label :clash_api_secret, class: "form-label" do %>
              Clash API Secret
              <% if @server.persisted? %>
                <span class="optional-text">(leave blank to keep current)</span>
              <% end %>
            <% end %>
            <%= form.password_field :clash_api_secret,
                class: "form-control",
                placeholder: "Secret for Clash external controller API",
                value: "" %>
            <small class="form-hint">Authentication token for Clash API (port 9090)</small>
          </div>
        </div>
      </div>

      <!-- SSH Authentication -->
      <div class="form-section">
        <div class="section-header">
          <h3 class="section-title">🔑 SSH Authentication</h3>
          <p class="section-description">Credentials for server management</p>
        </div>

        <div class="form-grid">
          <div class="form-group">
            <%= form.label :ssh_user, class: "form-label" do %>
              SSH Username <span class="required">*</span>
            <% end %>
            <%= form.text_field :ssh_user,
                class: "form-control",
                placeholder: "e.g., root",
                required: true %>
          </div>

          <div class="form-group">
            <%= form.label :ssh_password, class: "form-label" do %>
              SSH Password
              <% unless @server.persisted? %>
                <span class="required">*</span>
              <% else %>
                <span class="optional-text">(leave blank to keep current)</span>
              <% end %>
            <% end %>
            <%= form.password_field :ssh_password,
                class: "form-control",
                placeholder: "Enter SSH password",
                value: "" %>
          </div>

          <div class="form-group form-group-full">
            <%= form.label :ssh_public_key, class: "form-label" %>
            <%= form.text_area :ssh_public_key,
                class: "form-control form-textarea",
                placeholder: "Paste SSH public key here (optional)",
                rows: 2 %>
            <small class="form-hint">Public key for SSH authentication (recommended)</small>
          </div>

          <div class="form-group form-group-full">
            <%= form.label :ssh_private_key, class: "form-label" do %>
              SSH Private Key
              <% if @server.persisted? %>
                <span class="optional-text">(leave blank to keep current)</span>
              <% end %>
            <% end %>
            <%= form.text_area :ssh_private_key,
                class: "form-control form-textarea",
                placeholder: "Private key will be generated here...",
                rows: 5 %>
            <small class="form-hint">
              Private key for SSH authentication. If provided, password will not be used.
              <button type="button" id="generate-ssh-key" class="btn-link">
                Generate new key pair
              </button>
            </small>
          </div>
        </div>
      </div>
    </div>

    <!-- Form Actions -->
    <div class="form-actions">
      <%= link_to "Cancel", admin_servers_path, class: "btn btn-secondary" %>
      <%= form.submit @server.persisted? ? "Update Server" : "Create Server",
          class: "btn btn-primary",
          data: { disable_with: "Saving..." } %>
    </div>

  <% end %>
</div>

<style>
  /* Form Wrapper */
  .server-form-wrapper {
    max-width: 900px;
    margin: 0 auto;
  }

  .server-form {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  /* Alert Styles */
  .alert {
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 2rem;
    border-left: 4px solid;
  }

  .alert-error {
    background-color: #fee;
    border-color: #e74c3c;
  }

  .alert-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .alert-icon {
    font-size: 1.5rem;
  }

  .alert-title {
    margin: 0;
    color: #c0392b;
    font-size: 1rem;
    font-weight: 600;
  }

  .alert-list {
    margin: 0;
    padding-left: 2.5rem;
    color: #c0392b;
  }

  .alert-list li {
    margin-bottom: 0.5rem;
  }

  /* Form Sections */
  .form-sections {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .form-section {
    background-color: #f8f9fa;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .section-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e9ecef;
  }

  .section-title {
    margin: 0 0 0.5rem 0;
    color: #2c3e50;
    font-size: 1.25rem;
    font-weight: 600;
  }

  .section-description {
    margin: 0;
    color: #7f8c8d;
    font-size: 0.9rem;
  }

  /* Form Grid */
  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group-full {
    grid-column: 1 / -1;
  }

  /* Form Labels */
  .form-label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: #2c3e50;
    font-size: 0.95rem;
  }

  .required {
    color: #e74c3c;
    margin-left: 0.25rem;
  }

  .optional-text {
    font-weight: 400;
    color: #95a5a6;
    font-size: 0.85rem;
  }

  /* Form Controls */
  .form-control {
    padding: 0.75rem;
    border: 2px solid #e9ecef;
    border-radius: 6px;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    background-color: white;
  }

  .form-control:focus {
    outline: none;
    border-color: #9b59b6;
    box-shadow: 0 0 0 3px rgba(155, 89, 182, 0.1);
  }

  .form-textarea {
    resize: vertical;
    font-family: monospace;
    line-height: 1.5;
  }

  .form-hint {
    display: block;
    margin-top: 0.5rem;
    color: #7f8c8d;
    font-size: 0.85rem;
    line-height: 1.4;
  }

  /* Checkbox Styles */
  .form-group-checkbox {
    display: flex;
    align-items: center;
    grid-column: 1 / -1;
  }

  .form-checkbox {
    width: 20px;
    height: 20px;
    margin: 0;
    cursor: pointer;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    margin: 0;
    padding: 0.75rem;
    border-radius: 6px;
    transition: background-color 0.2s;
  }

  .checkbox-label:hover {
    background-color: rgba(155, 89, 182, 0.05);
  }

  .checkbox-text {
    font-weight: 500;
    color: #2c3e50;
  }

  /* Link Button */
  .btn-link {
    background: none;
    border: none;
    color: #9b59b6;
    text-decoration: none;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0;
    transition: color 0.2s;
  }

  .btn-link:hover {
    color: #8e44ad;
    text-decoration: underline;
  }

  /* Form Actions */
  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 2px solid #e9ecef;
  }

  .btn {
    padding: 0.75rem 2rem;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-block;
  }

  .btn-primary {
    background-color: #9b59b6;
    color: white;
  }

  .btn-primary:hover {
    background-color: #8e44ad;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(155, 89, 182, 0.3);
  }

  .btn-secondary {
    background-color: #95a5a6;
    color: white;
  }

  .btn-secondary:hover {
    background-color: #7f8c8d;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .server-form-wrapper {
      padding: 0;
    }

    .server-form {
      padding: 1rem;
      border-radius: 0;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .form-group-full {
      grid-column: 1;
    }

    .form-section {
      padding: 1rem;
    }

    .section-header {
      margin-bottom: 1rem;
    }

    .section-title {
      font-size: 1.1rem;
    }

    .form-actions {
      flex-direction: column-reverse;
    }

    .btn {
      width: 100%;
    }

    .alert {
      padding: 1rem;
    }

    .alert-list {
      padding-left: 1.5rem;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .section-title {
      font-size: 1rem;
    }

    .section-description {
      font-size: 0.85rem;
    }

    .form-control {
      font-size: 0.9rem;
      padding: 0.65rem;
    }

    .form-hint {
      font-size: 0.8rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const generateBtn = document.getElementById('generate-ssh-key');

    if (generateBtn) {
      generateBtn.addEventListener('click', async function(e) {
        e.preventDefault();

        // Show loading state
        const originalText = this.textContent;
        this.textContent = 'Generating...';
        this.disabled = true;

        try {
          const response = await fetch('<%= generate_ssh_key_admin_servers_path %>', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
            }
          });

          if (!response.ok) {
            throw new Error('Failed to generate SSH key pair');
          }

          const { private_key, public_key } = await response.json();

          // Fill in the form fields
          document.querySelector('#server_ssh_private_key').value = private_key;
          document.querySelector('#server_ssh_public_key').value = public_key;

          // Show success message
          alert('✓ New SSH key pair generated!\n\nThe public key has been filled in. Make sure to copy it to your server.');

        } catch (error) {
          console.error('Error:', error);
          alert('✗ Failed to generate SSH key pair. Please try again.');
        } finally {
          // Restore button state
          this.textContent = originalText;
          this.disabled = false;
        }
      });
    }
  });
</script>
