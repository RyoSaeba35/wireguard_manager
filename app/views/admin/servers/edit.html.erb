<%# app/views/admin/servers/edit.html.erb %>
<div class="admin-container">

  <div class="admin-content">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs">
      <%= link_to "Servers", admin_servers_path, class: "breadcrumb-link" %>
      <span class="breadcrumb-separator">›</span>
      <span class="breadcrumb-current">Edit <%= @server.name %></span>
    </nav>

    <!-- Page Header -->
    <div class="page-header">
      <div class="header-content">
        <h1>🖥️ Edit Server</h1>
        <p class="header-subtitle"><%= @server.name %></p>
      </div>
      <div class="header-actions">
        <%= link_to admin_servers_path, class: "btn-secondary" do %>
          <span class="btn-icon">←</span>
          Back to Servers
        <% end %>
      </div>
    </div>

    <!-- Server Status Card -->
    <div class="status-card">
      <div class="status-grid">
        <div class="status-item">
          <div class="status-label">Status</div>
          <div class="status-value">
            <% if @server.active %>
              <span class="badge badge-success">
                <span class="badge-dot"></span>
                Active
              </span>
            <% else %>
              <span class="badge badge-inactive">
                <span class="badge-dot"></span>
                Inactive
              </span>
            <% end %>
          </div>
        </div>

        <div class="status-item">
          <div class="status-label">Health</div>
          <div class="status-value">
            <% if @server.healthy %>
              <span class="badge badge-healthy">
                <span class="badge-dot"></span>
                Healthy
              </span>
            <% else %>
              <span class="badge badge-unhealthy">
                <span class="badge-dot"></span>
                Unhealthy
              </span>
            <% end %>
          </div>
        </div>

        <div class="status-item">
          <div class="status-label">Location</div>
          <div class="status-value">
            <span class="location-text">
              <%= @server.flag || '🌐' %>
              <%= @server.location || 'Not set' %>
            </span>
          </div>
        </div>

        <div class="status-item">
          <div class="status-label">IP Address</div>
          <div class="status-value">
            <code class="code-text"><%= @server.ip_address %></code>
          </div>
        </div>

        <div class="status-item">
          <div class="status-label">Active Connections</div>
          <div class="status-value">
            <span class="metric-value">
              <%= @server.vpn_config_sets.in_use.count %>/<%= @server.max_concurrent_connections %>
            </span>
            <span class="metric-percent">
              (<%= @server.max_concurrent_connections > 0 ? ((@server.vpn_config_sets.in_use.count.to_f / @server.max_concurrent_connections * 100).round(1)) : 0 %>%)
            </span>
          </div>
        </div>

        <div class="status-item">
          <div class="status-label">Pool Status</div>
          <div class="status-value">
            <span class="metric-value">
              <%= @server.vpn_config_sets.available.count %> available
            </span>
            /
            <span class="metric-total">
              <%= @server.vpn_config_sets.count %> total
            </span>
          </div>
        </div>
      </div>

      <!-- Last Updated Info -->
      <div class="update-info">
        <span class="update-label">Last updated:</span>
        <span class="update-time"><%= time_ago_in_words(@server.updated_at) %> ago</span>
        <% if @server.last_health_check %>
          <span class="update-separator">•</span>
          <span class="update-label">Last health check:</span>
          <span class="update-time"><%= time_ago_in_words(@server.last_health_check) %> ago</span>
        <% end %>
      </div>
    </div>

    <!-- Warning Messages -->
    <% if !@server.active %>
      <div class="alert alert-warning">
        <span class="alert-icon">⚠️</span>
        <div class="alert-content">
          <strong>Server Inactive</strong>
          <p>This server is currently inactive and not accepting new connections.</p>
        </div>
      </div>
    <% end %>

    <% if !@server.healthy %>
      <div class="alert alert-error">
        <span class="alert-icon">🔴</span>
        <div class="alert-content">
          <strong>Server Unhealthy</strong>
          <p>This server has failed <%= @server.health_failures || 0 %> consecutive health checks.</p>
        </div>
      </div>
    <% end %>

    <!-- Form Section -->
    <div class="form-section">
      <%= render 'form' %>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
      <h3 class="quick-actions-title">Quick Actions</h3>
      <div class="actions-grid">
        <%= button_to "🔄 Rebuild Config Pool",
            rebuild_pool_admin_server_path(@server),
            method: :post,
            class: "action-btn action-btn-primary",
            data: {
              confirm: "This will regenerate all #{@server.config_pool_size} config sets. This may take several minutes. Continue?"
            } %>

        <%= button_to @server.active ? "⏸️ Deactivate Server" : "▶️ Activate Server",
            toggle_active_admin_server_path(@server),
            method: :patch,
            class: @server.active ? "action-btn action-btn-warning" : "action-btn action-btn-success",
            data: {
              confirm: @server.active ? "Deactivate this server?" : "Activate this server?"
            } %>

        <%= link_to "📊 View Metrics",
            admin_server_path(@server),
            class: "action-btn action-btn-secondary" %>
      </div>
    </div>

    <!-- Danger Zone -->
    <div class="danger-zone">
      <div class="danger-zone-header">
        <h3 class="danger-zone-title">⚠️ Danger Zone</h3>
        <p class="danger-zone-description">Irreversible actions that require careful consideration</p>
      </div>
      <div class="danger-zone-content">
        <%= button_to "Delete Server",
            admin_server_path(@server),
            method: :delete,
            class: "btn-danger",
            data: {
              confirm: "Are you absolutely sure? This will delete the server, all its config sets, and disconnect all active users. This action cannot be undone.\n\nType '#{@server.name}' to confirm:"
            } %>
      </div>
    </div>
  </div>
</div>

<style>
  /* Base Layout */
  .admin-container {
    display: flex;
    justify-content: center;
    min-height: 100vh;
    background-color: #f5f6fa;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  }

  .admin-content {
    flex: 1;
    padding: 2rem;
    margin-left: 0px;
    max-width: 1200px;
  }

  /* Breadcrumbs */
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .breadcrumb-link {
    color: #7f8c8d;
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb-link:hover {
    color: #2c3e50;
  }

  .breadcrumb-separator {
    color: #bdc3c7;
  }

  .breadcrumb-current {
    color: #2c3e50;
    font-weight: 600;
  }

  /* Page Header */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .header-content h1 {
    color: #2c3e50;
    font-size: 2rem;
    margin: 0;
  }

  .header-subtitle {
    color: #7f8c8d;
    font-size: 1.1rem;
    margin: 0.5rem 0 0 0;
  }

  .header-actions {
    display: flex;
    gap: 1rem;
  }

  /* Buttons */
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: #95a5a6;
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .btn-secondary:hover {
    background-color: #7f8c8d;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(149, 165, 166, 0.3);
  }

  .btn-icon {
    font-size: 1.1rem;
  }

  /* Status Card */
  .status-card {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #ecf0f1;
  }

  .status-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .status-label {
    font-size: 0.85rem;
    color: #7f8c8d;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }

  .status-value {
    font-size: 1.1rem;
    color: #2c3e50;
    font-weight: 600;
  }

  /* Badges */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .badge-success {
    background-color: #d4edda;
    color: #155724;
  }

  .badge-success .badge-dot {
    background-color: #28a745;
  }

  .badge-inactive {
    background-color: #f8d7da;
    color: #721c24;
  }

  .badge-inactive .badge-dot {
    background-color: #dc3545;
  }

  .badge-healthy {
    background-color: #d4edda;
    color: #155724;
  }

  .badge-healthy .badge-dot {
    background-color: #28a745;
  }

  .badge-unhealthy {
    background-color: #f8d7da;
    color: #721c24;
  }

  .badge-unhealthy .badge-dot {
    background-color: #dc3545;
  }

  /* Text Styles */
  .location-text {
    font-size: 1rem;
  }

  .code-text {
    background-color: #f8f9fa;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    font-size: 0.9rem;
  }

  .metric-value {
    color: #2c3e50;
  }

  .metric-percent,
  .metric-total {
    color: #7f8c8d;
    font-size: 0.9rem;
  }

  /* Update Info */
  .update-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: #7f8c8d;
  }

  .update-label {
    font-weight: 600;
  }

  .update-time {
    color: #95a5a6;
  }

  .update-separator {
    color: #bdc3c7;
  }

  /* Alerts */
  .alert {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    border-left: 4px solid;
  }

  .alert-warning {
    background-color: #fff3cd;
    border-color: #f39c12;
  }

  .alert-error {
    background-color: #f8d7da;
    border-color: #e74c3c;
  }

  .alert-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .alert-content strong {
    display: block;
    margin-bottom: 0.25rem;
    color: #2c3e50;
  }

  .alert-content p {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
  }

  /* Form Section */
  .form-section {
    margin-bottom: 2rem;
  }

  /* Quick Actions */
  .quick-actions {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .quick-actions-title {
    margin: 0 0 1.5rem 0;
    color: #2c3e50;
    font-size: 1.25rem;
  }

  .actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .action-btn {
    padding: 1rem;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    text-align: center;
    display: block;
  }

  .action-btn-primary {
    background-color: #3498db;
    color: white;
  }

  .action-btn-primary:hover {
    background-color: #2980b9;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(52, 152, 219, 0.3);
  }

  .action-btn-success {
    background-color: #2ecc71;
    color: white;
  }

  .action-btn-success:hover {
    background-color: #27ae60;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(46, 204, 113, 0.3);
  }

  .action-btn-warning {
    background-color: #f39c12;
    color: white;
  }

  .action-btn-warning:hover {
    background-color: #e67e22;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(243, 156, 18, 0.3);
  }

  .action-btn-secondary {
    background-color: #95a5a6;
    color: white;
  }

  .action-btn-secondary:hover {
    background-color: #7f8c8d;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(149, 165, 166, 0.3);
  }

  /* Danger Zone */
  .danger-zone {
    background: white;
    border: 2px solid #e74c3c;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .danger-zone-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f8d7da;
  }

  .danger-zone-title {
    margin: 0 0 0.5rem 0;
    color: #c0392b;
    font-size: 1.25rem;
  }

  .danger-zone-description {
    margin: 0;
    color: #7f8c8d;
    font-size: 0.9rem;
  }

  .btn-danger {
    padding: 0.75rem 2rem;
    background-color: #e74c3c;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-danger:hover {
    background-color: #c0392b;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(231, 76, 60, 0.3);
  }

  /* Mobile Responsive */
  @media (max-width: 1024px) {
    .admin-content {
      margin-left: 0;
      padding: 1rem;
    }

    .status-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }

  @media (max-width: 768px) {
    .page-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .header-content h1 {
      font-size: 1.5rem;
    }

    .header-subtitle {
      font-size: 1rem;
    }

    .header-actions {
      width: 100%;
    }

    .btn-secondary {
      width: 100%;
      justify-content: center;
    }

    .status-card {
      padding: 1rem;
    }

    .status-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .quick-actions {
      padding: 1rem;
    }

    .actions-grid {
      grid-template-columns: 1fr;
    }

    .danger-zone {
      padding: 1rem;
    }

    .btn-danger {
      width: 100%;
    }

    .update-info {
      font-size: 0.8rem;
    }

    .breadcrumbs {
      font-size: 0.85rem;
    }
  }
</style>
