<div class="admin-sidebar">
  <h2>Admin Panel</h2>
  <ul>
    <li><a href="<%= admin_users_path %>" class="<%= 'active' if current_page?(admin_users_path) %>">Users</a></li>
    <li><a href="<%= admin_servers_path %>" class="<%= 'active' if current_page?(admin_servers_path) %>">Servers</a></li>
    <li><a href="<%= admin_plans_path %>" class="<%= 'active' if current_page?(admin_plans_path) %>">Plans</a></li>
  </ul>
</div>

<style>
  /* Sidebar */
  .admin-sidebar {
    width: 200px;
    background: #2c3e50;
    color: white;
    padding: 20px 0;
    position: fixed;
    height: 100%;
    box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
  }
  .admin-sidebar h2 {
    padding: 0 20px 20px;
    font-size: 20px;
    color: #ecf0f1;
  }
  .admin-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .admin-sidebar li a {
    display: block;
    padding: 12px 20px;
    color: #bdc3c7;
    text-decoration: none;
    transition: background 0.2s;
  }
  .admin-sidebar li a:hover,
  .admin-sidebar li a.active {
    background: #34495e;
    color: white;
  }
</style>
