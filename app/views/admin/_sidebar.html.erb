<%# app/views/admin/_sidebar.html.erb %>

<!-- Mobile Menu Toggle -->
<button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
</button>

<!-- Sidebar Overlay (Mobile) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Admin Sidebar -->
<aside class="admin-sidebar" id="adminSidebar">
  <!-- Sidebar Header -->
  <div class="sidebar-header">
    <div class="sidebar-logo">
      <%= image_tag "Vulcain_VPN_logo_4.png", alt: "Vulcain VPN Logo", class: "logo" %>
    </div>
    <button class="sidebar-close" id="sidebarClose" aria-label="Close menu">×</button>
  </div>

  <!-- Admin Badge -->
  <div class="admin-badge">
    <div class="admin-avatar">
      <%= current_user.email.first.upcase %>
    </div>
    <div class="admin-info">
      <div class="admin-name"><%= current_user.email.split('@').first %></div>
      <div class="admin-role">Administrator</div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="sidebar-nav">
    <!-- Dashboard -->
    <%= link_to admin_dashboard_path, class: "nav-link #{current_page?(admin_dashboard_path) ? 'active' : ''}" do %>
      <span class="nav-icon">📊</span>
      <span class="nav-text">Dashboard</span>
    <% end %>

    <!-- Users -->
    <%= link_to admin_users_path, class: "nav-link #{current_page?(admin_users_path) ? 'active' : ''}" do %>
      <span class="nav-icon">👥</span>
      <span class="nav-text">Users</span>
      <% if defined?(@pending_users_count) && @pending_users_count > 0 %>
        <span class="nav-badge"><%= @pending_users_count %></span>
      <% end %>
    <% end %>

    <!-- Servers -->
    <%= link_to admin_servers_path, class: "nav-link #{current_page?(admin_servers_path) || controller_name == 'servers' ? 'active' : ''}" do %>
      <span class="nav-icon">🖥️</span>
      <span class="nav-text">Servers</span>
    <% end %>

    <!-- Plans -->
    <%= link_to admin_plans_path, class: "nav-link #{current_page?(admin_plans_path) || controller_name == 'plans' ? 'active' : ''}" do %>
      <span class="nav-icon">💎</span>
      <span class="nav-text">Plans</span>
    <% end %>

    <!-- Subscriptions -->
    <%= link_to admin_subscriptions_path, class: "nav-link #{current_page?(admin_subscriptions_path) || controller_name == 'subscriptions' ? 'active' : ''}" do %>
      <span class="nav-icon">📋</span>
      <span class="nav-text">Subscriptions</span>
    <% end %>

    <%# ⭐ REMOVED: Connections route doesn't exist yet %>
    <%# Uncomment when you create Admin::ConnectionsController %>
    <%#
    <%= link_to admin_connections_path, class: "nav-link #{current_page?(admin_connections_path) ? 'active' : ''}" do %>
      <%# <span class="nav-icon">🔌</span> %>
      <%# <span class="nav-text">Connections</span> %>
    <%# end %>

    <div class="nav-divider"></div>

    <!-- Settings -->
    <%# ⭐ FIXED: Changed admin_settings_path to edit_admin_setting_path %>
    <%= link_to edit_admin_setting_path, class: "nav-link #{current_page?(edit_admin_setting_path) ? 'active' : ''}" do %>
      <span class="nav-icon">⚙️</span>
      <span class="nav-text">Settings</span>
    <% end %>
  </nav>

  <!-- Sidebar Footer -->
  <div class="sidebar-footer">
    <%= link_to root_path, class: "footer-link" do %>
      <span class="nav-icon">🏠</span>
      <span class="nav-text">Back to App</span>
    <% end %>
    <%= link_to destroy_user_session_path, method: :delete, class: "footer-link footer-link-danger", data: { turbo_method: :delete } do %>
      <span class="nav-icon">🚪</span>
      <span class="nav-text">Logout</span>
    <% end %>
  </div>
</aside>

<style>
  .logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: white;
    text-decoration: none;
    height: 60px; /* Adjust as needed */
    margin: 10px 2rem;
  }
  .logo-link {
    display: flex;
    align-items: center;
  }

  .logo:hover {
    text-decoration: none;
    opacity: 0.9;
  }
  /* Mobile Menu Toggle Button */
  .mobile-menu-toggle {
    display: none;
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 1001;
    background: #9b59b6;
    border: none;
    padding: 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    transition: all 0.2s ease;
  }

  .mobile-menu-toggle:hover {
    background: #8e44ad;
    transform: scale(1.05);
  }

  .mobile-menu-toggle:active {
    transform: scale(0.95);
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 3px;
    background: white;
    border-radius: 2px;
    margin: 4px 0;
    transition: all 0.3s ease;
  }

  /* Sidebar Overlay (Mobile) */
  .sidebar-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 998;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .sidebar-overlay.active {
    opacity: 1;
  }

  /* Admin Sidebar */
  .admin-sidebar {
    width: 280px;
    background: #432923;
    color: #ecf0f1;
    position: fixed;
    left: 0;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
    z-index: 999;
    transition: transform 0.3s ease;
    overflow-y: auto;
    overflow-x: hidden;
  }

  /* Sidebar Header */
  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
  }

  .logo-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .logo-text {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    background: linear-gradient(135deg, #9b59b6, #e74c3c);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .sidebar-close {
    display: none;
    background: none;
    border: none;
    color: #ecf0f1;
    font-size: 2rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: color 0.2s;
  }

  .sidebar-close:hover {
    color: #e74c3c;
  }

  /* Admin Badge */
  .admin-badge {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .admin-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #9b59b6, #e74c3c);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }

  .admin-info {
    flex: 1;
    min-width: 0;
  }

  .admin-name {
    font-weight: 600;
    font-size: 1rem;
    color: #ecf0f1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .admin-role {
    font-size: 0.85rem;
    color: #9b59b6;
    font-weight: 500;
  }

  /* Navigation */
  .sidebar-nav {
    flex: 1;
    padding: 1rem 0;
    overflow-y: auto;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.5rem;
    color: #bdc3c7;
    text-decoration: none;
    transition: all 0.2s ease;
    position: relative;
    border-left: 3px solid transparent;
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #ecf0f1;
    border-left-color: rgba(155, 89, 182, 0.3);
  }

  .nav-link.active {
    background: rgba(155, 89, 182, 0.2);
    color: #fff;
    border-left-color: #9b59b6;
    font-weight: 600;
  }

  .nav-link.active .nav-icon {
    transform: scale(1.1);
  }

  .nav-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .nav-text {
    flex: 1;
    font-size: 0.95rem;
  }

  .nav-badge {
    background: #e74c3c;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 12px;
    min-width: 20px;
    text-align: center;
  }

  .nav-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 1rem 1.5rem;
  }

  /* Sidebar Footer */
  .sidebar-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1rem 0;
  }

  .footer-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    color: #bdc3c7;
    text-decoration: none;
    transition: all 0.2s ease;
    font-size: 0.9rem;
  }

  .footer-link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #ecf0f1;
  }

  .footer-link-danger:hover {
    background: rgba(231, 76, 60, 0.1);
    color: #e74c3c;
  }

  /* Scrollbar Styling */
  .sidebar-nav::-webkit-scrollbar,
  .admin-sidebar::-webkit-scrollbar {
    width: 6px;
  }

  .sidebar-nav::-webkit-scrollbar-track,
  .admin-sidebar::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.1);
  }

  .sidebar-nav::-webkit-scrollbar-thumb,
  .admin-sidebar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 3px;
  }

  .sidebar-nav::-webkit-scrollbar-thumb:hover,
  .admin-sidebar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  /* Mobile Responsive */
  @media (max-width: 1024px) {
    .mobile-menu-toggle {
      display: block;
    }

    .sidebar-close {
      display: block;
    }

    .admin-sidebar {
      transform: translateX(-100%);
    }

    .admin-sidebar.active {
      transform: translateX(0);
    }

    .sidebar-overlay {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .admin-sidebar {
      width: 85%;
      max-width: 320px;
    }

    .sidebar-header {
      padding: 1rem;
    }

    .logo-text {
      font-size: 1.25rem;
    }

    .logo-icon {
      font-size: 1.5rem;
    }

    .admin-badge {
      padding: 1rem;
    }

    .admin-avatar {
      width: 40px;
      height: 40px;
      font-size: 1.1rem;
    }

    .nav-link {
      padding: 0.75rem 1rem;
    }

    .nav-icon {
      font-size: 1.1rem;
    }

    .nav-text {
      font-size: 0.9rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sidebar = document.getElementById('adminSidebar');
    const overlay = document.getElementById('sidebarOverlay');
    const mobileToggle = document.getElementById('mobileMenuToggle');
    const sidebarClose = document.getElementById('sidebarClose');

    function openSidebar() {
      sidebar.classList.add('active');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
      sidebar.classList.remove('active');
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    // Mobile toggle button
    if (mobileToggle) {
      mobileToggle.addEventListener('click', openSidebar);
    }

    // Close button
    if (sidebarClose) {
      sidebarClose.addEventListener('click', closeSidebar);
    }

    // Overlay click
    if (overlay) {
      overlay.addEventListener('click', closeSidebar);
    }

    // Close on navigation (mobile)
    const navLinks = sidebar.querySelectorAll('.nav-link');
    navLinks.forEach(link => {
      link.addEventListener('click', function() {
        if (window.innerWidth <= 1024) {
          closeSidebar();
        }
      });
    });

    // Handle window resize
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        if (window.innerWidth > 1024) {
          closeSidebar();
        }
      }, 250);
    });

    // Escape key to close
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && sidebar.classList.contains('active')) {
        closeSidebar();
      }
    });
  });
</script>
