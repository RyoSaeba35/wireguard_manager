<!-- app/views/admin/users/index.html.erb -->
<div class="admin-container">
  <!-- Main Content: Users Page -->
  <div class="admin-content">
    <div class="page-header">
      <h1>Users</h1>
      <p class="users-stats">
        <span class="stat-item">Total: <strong><%= @users.total_count %></strong></span>
        <span class="stat-divider">•</span>
        <span class="stat-item">Page: <strong><%= @users.current_page %> of <%= @users.total_pages %></strong></span>
        <span class="stat-divider">•</span>
        <span class="stat-item">Active Users: <strong><%= @active_subscriptions_by_user.keys.count %></strong></span>
      </p>
    </div>

    <!-- Search and Filter Controls -->
    <div class="controls">
      <input type="text" id="search-input" placeholder="Search by email..." class="search-input">
      <div class="filter-options">
        <label class="checkbox-label">
          <input type="checkbox" id="hide-inactive">
          <span>Hide inactive users</span>
        </label>
      </div>
    </div>

    <!-- Desktop: Users Table -->
    <div class="desktop-table">
      <table class="users-table">
        <thead>
          <tr>
            <th>Email</th>
            <th>Active</th>
            <th>Status</th>
            <th>Expired</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="users-table-body">
          <% @users.each do |user| %>
            <% active_count = active_subscriptions_count(user) %>
            <% expired_count = expired_subscriptions_count(user) %>
            <% has_active = has_active_subscription?(user) %>

            <tr class="user-row"
                data-email="<%= user.email.downcase %>"
                data-has-active="<%= has_active ? 'true' : 'false' %>"
                data-user-id="<%= user.id %>">
              <td><%= user.email %></td>
              <td>
                <% if active_count > 0 %>
                  <button class="toggle-details" data-target="<%= user.id %>-active" aria-expanded="false">
                    <%= active_count %> <span class="toggle-span">(Show)</span>
                  </button>
                <% else %>
                  <span class="count-display">0</span>
                <% end %>
              </td>
              <td>
                <% if has_active %>
                  <span class="status-badge status-active">Active</span>
                <% else %>
                  <span class="status-badge status-inactive">Inactive</span>
                <% end %>
              </td>
              <td>
                <% if expired_count > 0 %>
                  <button class="toggle-details" data-target="<%= user.id %>-expired" aria-expanded="false">
                    <%= expired_count %> <span class="toggle-span">(Show)</span>
                  </button>
                <% else %>
                  <span class="count-display">0</span>
                <% end %>
              </td>
              <td class="actions-cell">
                <div class="dropdown">
                  <button class="dropdown-btn">⋮</button>
                  <div class="dropdown-menu">
                    <% unless has_active %>
                      <a href="#" class="dropdown-item add-subscription-btn" data-user-id="<%= user.id %>">
                        <span class="dropdown-icon">➕</span> Add Subscription
                      </a>
                    <% else %>
                      <span class="dropdown-item disabled">Has active subscription</span>
                    <% end %>
                    <% if user.id != current_user.id %>
                      <%= form_with(
                            url: admin_user_path(user),
                            method: :delete,
                            class: "delete-user-form",
                            data: { turbo: false }
                          ) do |f| %>
                        <button type="submit" class="dropdown-item delete-user-btn" data-user-id="<%= user.id %>">
                          <span class="dropdown-icon">🗑️</span> Delete User
                        </button>
                      <% end %>
                    <% else %>
                      <span class="dropdown-item disabled">Cannot delete yourself</span>
                    <% end %>
                  </div>
                </div>
              </td>
            </tr>

            <!-- Active Subscriptions Details Row -->
            <% if active_count > 0 %>
              <tr id="<%= user.id %>-active" class="details-row" aria-expanded="false" style="display: none;">
                <td colspan="5">
                  <div class="details-content">
                    <strong>Active Subscriptions</strong>
                    <table class="subscription-table">
                      <thead>
                        <tr>
                          <th>Plan</th>
                          <th>Expires</th>
                          <th>Devices</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% user_subscriptions(user, :active).each do |subscription| %>
                          <tr>
                            <td><%= subscription.plan&.name || 'Custom' %></td>
                            <td><%= subscription.expires_at&.strftime("%d %b %Y") || 'Never' %></td>
                            <td><%= subscription.devices.count %>/<%= subscription.max_devices || 3 %></td>
                            <td>
                              <button class="btn-cancel cancel-subscription-btn"
                                      data-subscription-id="<%= subscription.id %>"
                                      data-user-id="<%= user.id %>">
                                Cancel
                              </button>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                </td>
              </tr>
            <% end %>

            <!-- Expired Subscriptions Details Row -->
            <% if expired_count > 0 %>
              <tr id="<%= user.id %>-expired" class="details-row" aria-expanded="false" style="display: none;">
                <td colspan="5">
                  <div class="details-content">
                    <strong>Expired Subscriptions</strong>
                    <table class="subscription-table">
                      <thead>
                        <tr>
                          <th>Plan</th>
                          <th>Expired</th>
                          <th>Devices</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% user_subscriptions(user, :expired).each do |subscription| %>
                          <tr>
                            <td><%= subscription.plan&.name || 'Custom' %></td>
                            <td><%= subscription.expires_at&.strftime("%d %b %Y") || 'N/A' %></td>
                            <td><%= subscription.devices.count %>/<%= subscription.max_devices || 3 %></td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Mobile: User Cards -->
    <div class="mobile-cards">
      <% @users.each do |user| %>
        <% active_count = active_subscriptions_count(user) %>
        <% expired_count = expired_subscriptions_count(user) %>
        <% has_active = has_active_subscription?(user) %>

        <div class="user-card"
             data-email="<%= user.email.downcase %>"
             data-has-active="<%= has_active ? 'true' : 'false' %>"
             data-user-id="<%= user.id %>">

          <div class="user-card-header">
            <div class="user-info">
              <div class="user-email"><%= user.email %></div>
              <% if has_active %>
                <span class="status-badge status-active">Active</span>
              <% else %>
                <span class="status-badge status-inactive">Inactive</span>
              <% end %>
            </div>
            <div class="dropdown">
              <button class="dropdown-btn-mobile">⋮</button>
              <div class="dropdown-menu">
                <% unless has_active %>
                  <a href="#" class="dropdown-item add-subscription-btn" data-user-id="<%= user.id %>">
                    ➕ Add Subscription
                  </a>
                <% else %>
                  <span class="dropdown-item disabled">Has active subscription</span>
                <% end %>
                <% if user.id != current_user.id %>
                  <%= form_with(
                        url: admin_user_path(user),
                        method: :delete,
                        class: "delete-user-form",
                        data: { turbo: false }
                      ) do |f| %>
                    <button type="submit" class="dropdown-item delete-user-btn" data-user-id="<%= user.id %>">
                      🗑️ Delete User
                    </button>
                  <% end %>
                <% else %>
                  <span class="dropdown-item disabled">Cannot delete yourself</span>
                <% end %>
              </div>
            </div>
          </div>

          <div class="user-card-body">
            <div class="subscription-info">
              <div class="info-item">
                <span class="info-label">Active:</span>
                <% if active_count > 0 %>
                  <button class="toggle-details-mobile" data-target="mobile-<%= user.id %>-active">
                    <%= active_count %> <span class="toggle-span">(Show)</span>
                  </button>
                <% else %>
                  <span class="info-value">0</span>
                <% end %>
              </div>
              <div class="info-item">
                <span class="info-label">Expired:</span>
                <% if expired_count > 0 %>
                  <button class="toggle-details-mobile" data-target="mobile-<%= user.id %>-expired">
                    <%= expired_count %> <span class="toggle-span">(Show)</span>
                  </button>
                <% else %>
                  <span class="info-value">0</span>
                <% end %>
              </div>
            </div>

            <!-- Active Subscriptions Details (Mobile) -->
            <% if active_count > 0 %>
              <div id="mobile-<%= user.id %>-active" class="details-mobile" style="display: none;">
                <div class="details-header">Active Subscriptions</div>
                <% user_subscriptions(user, :active).each do |subscription| %>
                  <div class="subscription-item">
                    <div class="sub-row">
                      <span class="sub-label">Plan:</span>
                      <span class="sub-value"><%= subscription.plan&.name || 'Custom' %></span>
                    </div>
                    <div class="sub-row">
                      <span class="sub-label">Expires:</span>
                      <span class="sub-value"><%= subscription.expires_at&.strftime("%d %b %Y") || 'Never' %></span>
                    </div>
                    <div class="sub-row">
                      <span class="sub-label">Devices:</span>
                      <span class="sub-value"><%= subscription.devices.count %>/<%= subscription.max_devices || 3 %></span>
                    </div>
                    <button class="btn-cancel-mobile cancel-subscription-btn"
                            data-subscription-id="<%= subscription.id %>"
                            data-user-id="<%= user.id %>">
                      Cancel Subscription
                    </button>
                  </div>
                <% end %>
              </div>
            <% end %>

            <!-- Expired Subscriptions Details (Mobile) -->
            <% if expired_count > 0 %>
              <div id="mobile-<%= user.id %>-expired" class="details-mobile" style="display: none;">
                <div class="details-header">Expired Subscriptions</div>
                <% user_subscriptions(user, :expired).each do |subscription| %>
                  <div class="subscription-item">
                    <div class="sub-row">
                      <span class="sub-label">Plan:</span>
                      <span class="sub-value"><%= subscription.plan&.name || 'Custom' %></span>
                    </div>
                    <div class="sub-row">
                      <span class="sub-label">Expired:</span>
                      <span class="sub-value"><%= subscription.expires_at&.strftime("%d %b %Y") || 'N/A' %></span>
                    </div>
                    <div class="sub-row">
                      <span class="sub-label">Devices:</span>
                      <span class="sub-value"><%= subscription.devices.count %>/<%= subscription.max_devices || 3 %></span>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Pagination -->
    <div class="pagination-container">
      <%= paginate @users %>
    </div>
  </div>

  <!-- Add Subscription Modal -->
  <div id="add-subscription-modal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3>Add Subscription</h3>
        <button class="close-modal" aria-label="Close">&times;</button>
      </div>
      <p class="modal-description">Create a new subscription for this user (no payment required).</p>
      <form id="add-subscription-form">
        <input type="hidden" id="subscription-user-id">

        <div class="form-group">
          <label for="subscription-plan">Plan:</label>
          <select id="subscription-plan" required>
            <option value="">Select a plan</option>
            <% @plans.each do |plan| %>
              <option value="<%= plan.id %>">
                <%= plan.name %> (€<%= plan.price %>/<%= plan.interval %>)
              </option>
            <% end %>
          </select>
        </div>

        <div class="form-group">
          <label for="subscription-expires-at">Expires At:</label>
          <input type="datetime-local" id="subscription-expires-at" required>
        </div>

        <div class="modal-actions">
          <button type="button" class="btn-secondary close-modal-btn">Cancel</button>
          <button type="submit" class="btn-primary">Create Subscription</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Use a single initialization with proper cleanup
  (function() {
    let initialized = false;

    function initializeUsersPage() {
      if (initialized) return;
      initialized = true;

      setupEventListeners();
    }

    // Initialize on Turbo load
    document.addEventListener('turbo:load', initializeUsersPage);

    // Reset on navigation away
    document.addEventListener('turbo:before-render', function() {
      initialized = false;
    });

    function setupEventListeners() {
      // Use event delegation for all dynamic elements - attach to document once

      // Toggle Details (Desktop) - Event Delegation
      document.addEventListener('click', function(e) {
        if (e.target.closest('.toggle-details')) {
          const button = e.target.closest('.toggle-details');
          const targetId = button.getAttribute('data-target');
          const detailsRow = document.getElementById(targetId);
          if (!detailsRow) return;

          const isExpanded = detailsRow.getAttribute('aria-expanded') === 'true';
          button.setAttribute('aria-expanded', !isExpanded);
          detailsRow.setAttribute('aria-expanded', !isExpanded);
          detailsRow.style.display = isExpanded ? 'none' : 'table-row';
          const toggleSpan = button.querySelector('.toggle-span');
          if (toggleSpan) {
            toggleSpan.textContent = isExpanded ? '(Show)' : '(Hide)';
          }
        }
      });

      // Toggle Details (Mobile) - Event Delegation
      document.addEventListener('click', function(e) {
        if (e.target.closest('.toggle-details-mobile')) {
          const button = e.target.closest('.toggle-details-mobile');
          const targetId = button.getAttribute('data-target');
          const detailsDiv = document.getElementById(targetId);
          if (!detailsDiv) return;

          const isVisible = detailsDiv.style.display !== 'none';
          detailsDiv.style.display = isVisible ? 'none' : 'block';
          const toggleSpan = button.querySelector('.toggle-span');
          if (toggleSpan) {
            toggleSpan.textContent = isVisible ? '(Show)' : '(Hide)';
          }
        }
      });

      // Search and Filter
      const searchInput = document.getElementById('search-input');
      const hideInactive = document.getElementById('hide-inactive');

      function filterUsers() {
        const searchTerm = searchInput ? searchInput.value.toLowerCase() : '';
        const hideInactiveChecked = hideInactive ? hideInactive.checked : false;

        // Filter desktop table rows
        document.querySelectorAll('.user-row').forEach(row => {
          const email = row.getAttribute('data-email');
          const hasActive = row.getAttribute('data-has-active') === 'true';
          const emailMatch = email.includes(searchTerm);
          row.style.display = ((searchTerm === '' || emailMatch) && (!hideInactiveChecked || hasActive)) ? '' : 'none';
        });

        // Filter mobile cards
        document.querySelectorAll('.user-card').forEach(card => {
          const email = card.getAttribute('data-email');
          const hasActive = card.getAttribute('data-has-active') === 'true';
          const emailMatch = email.includes(searchTerm);
          card.style.display = ((searchTerm === '' || emailMatch) && (!hideInactiveChecked || hasActive)) ? '' : 'none';
        });
      }

      if (searchInput) {
        searchInput.addEventListener('keyup', filterUsers);
      }
      if (hideInactive) {
        hideInactive.addEventListener('change', filterUsers);
      }

      // Dropdown functionality - Event delegation
      document.addEventListener('click', function(e) {
        // Close all dropdowns if clicking outside
        if (!e.target.closest('.dropdown-btn') &&
            !e.target.closest('.dropdown-btn-mobile') &&
            !e.target.closest('.dropdown-menu')) {
          document.querySelectorAll('.dropdown-menu').forEach(dropdown => {
            dropdown.classList.remove('show');
            dropdown.classList.remove('dropup'); // Remove dropup class when closing
          });
          return;
        }

        // Toggle dropdown if clicking button
        if (e.target.closest('.dropdown-btn') || e.target.closest('.dropdown-btn-mobile')) {
          e.stopPropagation();
          // Close all other dropdowns first
          document.querySelectorAll('.dropdown-menu').forEach(dropdown => {
            dropdown.classList.remove('show');
            dropdown.classList.remove('dropup');
          });

          // Open this dropdown
          const button = e.target.closest('.dropdown-btn') || e.target.closest('.dropdown-btn-mobile');
          const dropdown = e.target.closest('.dropdown').querySelector('.dropdown-menu');

          if (dropdown) {
            // Check if dropdown would be cut off at bottom
            const rect = button.getBoundingClientRect();
            const dropdownHeight = 200; // Approximate max dropdown height
            const spaceBelow = window.innerHeight - rect.bottom;
            const spaceAbove = rect.top;

            // If not enough space below but enough above, open upward
            if (spaceBelow < dropdownHeight && spaceAbove > dropdownHeight) {
              dropdown.classList.add('dropup');
            }

            dropdown.classList.add('show');
          }
        }

        // Handle dropdown item clicks
        if (e.target.closest('.dropdown-item')) {
          const item = e.target.closest('.dropdown-item');
          if (item.classList.contains('add-subscription-btn')) {
            e.preventDefault();
            openAddSubscriptionModal(item.getAttribute('data-user-id'));
          }
          const menu = item.closest('.dropdown-menu');
          if (menu) {
            menu.classList.remove('show');
            menu.classList.remove('dropup');
          }
        }
      });

      // Delete User - Event Delegation
      document.addEventListener('submit', function(e) {
        if (e.target.classList.contains('delete-user-form')) {
          e.preventDefault();
          const form = e.target;
          const button = form.querySelector('.delete-user-btn');
          const userId = button.dataset.userId;

          if (!confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
            return;
          }

          const originalText = button.textContent;
          button.textContent = 'Deleting...';
          button.disabled = true;

          fetch(form.action, {
            method: 'DELETE',
            headers: {
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
              'Accept': 'application/json',
              'Content-Type': 'application/json'
            }
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              document.querySelector(`.user-row[data-user-id="${userId}"]`)?.remove();
              document.querySelector(`.user-card[data-user-id="${userId}"]`)?.remove();
              alert('User deleted successfully!');

              // Update stats
              const statsElement = document.querySelector('.users-stats');
              if (statsElement) {
                const totalUsersMatch = statsElement.textContent.match(/Total:\s*(\d+)/);
                if (totalUsersMatch) {
                  const currentTotal = parseInt(totalUsersMatch[1]);
                  const activeUsersCount = document.querySelectorAll('[data-has-active="true"]').length;
                  statsElement.innerHTML = `<span class="stat-item">Total: <strong>${currentTotal - 1}</strong></span><span class="stat-divider">•</span><span class="stat-item">Active: <strong>${activeUsersCount}</strong></span>`;
                }
              }
            } else {
              throw new Error(data.error || 'Failed to delete user');
            }
          })
          .catch(error => {
            button.textContent = originalText;
            button.disabled = false;
            alert('Error: ' + error.message);
          });
        }
      });

      // Plan data for auto-calculation
      const planData = {
        <% @plans.each do |plan| %>
          '<%= plan.id %>': { interval: '<%= plan.interval %>' },
        <% end %>
      };

      function calculateExpiration(interval) {
        const now = new Date();
        let expirationDate;
        switch(interval) {
          case 'week':
            expirationDate = new Date(now.getTime() + 7 * 24 * 60 * 60 * 1000);
            break;
          case 'month':
            expirationDate = new Date(now.setMonth(now.getMonth() + 1));
            break;
          default:
            expirationDate = new Date(now.setMonth(now.getMonth() + 1));
        }
        return expirationDate.toISOString().slice(0, 16);
      }

      const planSelect = document.getElementById('subscription-plan');
      const expiresAtInput = document.getElementById('subscription-expires-at');

      if (planSelect && expiresAtInput) {
        planSelect.addEventListener('change', function() {
          const selectedPlanId = this.value;
          if (selectedPlanId && planData[selectedPlanId]) {
            expiresAtInput.value = calculateExpiration(planData[selectedPlanId].interval);
          }
        });
      }

      // Modal handling
      function openAddSubscriptionModal(userId) {
        document.getElementById('subscription-user-id').value = userId;
        document.getElementById('subscription-plan').selectedIndex = 0;

        const defaultExpiresAt = new Date();
        defaultExpiresAt.setMonth(defaultExpiresAt.getMonth() + 1);
        document.getElementById('subscription-expires-at').value = defaultExpiresAt.toISOString().slice(0, 16);

        document.getElementById('add-subscription-modal').style.display = 'block';
        document.body.style.overflow = 'hidden';
      }

      // Close Modal - Event Delegation
      document.addEventListener('click', function(e) {
        if (e.target.classList.contains('close-modal') || e.target.classList.contains('close-modal-btn')) {
          document.querySelectorAll('.modal').forEach(modal => {
            modal.style.display = 'none';
          });
          document.body.style.overflow = 'auto';
        }
      });

      // Add Subscription Form - Single listener with prevention
      const addSubForm = document.getElementById('add-subscription-form');
      if (addSubForm) {
        // Remove any existing listeners by cloning
        const newForm = addSubForm.cloneNode(true);
        addSubForm.parentNode.replaceChild(newForm, addSubForm);

        // Add single listener to new form
        newForm.addEventListener('submit', function(e) {
          e.preventDefault();

          const submitButton = this.querySelector('button[type="submit"]');

          // Prevent double submission
          if (submitButton.disabled) {
            return;
          }

          const originalText = submitButton.textContent;
          submitButton.textContent = 'Adding...';
          submitButton.disabled = true;

          const userId = document.getElementById('subscription-user-id').value;
          const planId = document.getElementById('subscription-plan').value;
          const expiresAt = document.getElementById('subscription-expires-at').value;

          if (!planId || !expiresAt) {
            alert('Please fill in all fields');
            submitButton.textContent = originalText;
            submitButton.disabled = false;
            return;
          }

          fetch(`/admin/users/${userId}/subscriptions`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
            },
            body: JSON.stringify({
              subscription: { plan_id: planId, expires_at: expiresAt }
            })
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              document.getElementById('add-subscription-modal').style.display = 'none';
              document.body.style.overflow = 'auto';
              alert('Subscription added successfully!');
              window.location.reload();
            } else {
              throw new Error(data.error || 'Failed to add subscription');
            }
          })
          .catch(error => {
            alert('Error: ' + error.message);
          })
          .finally(() => {
            submitButton.textContent = originalText;
            submitButton.disabled = false;
          });
        });
      }

      // Cancel Subscription - Event Delegation
      document.addEventListener('click', function(e) {
        if (e.target.classList.contains('cancel-subscription-btn')) {
          const button = e.target;
          const subscriptionId = button.getAttribute('data-subscription-id');
          const userId = button.getAttribute('data-user-id');

          if (confirm('Are you sure you want to cancel this subscription?')) {
            const originalText = button.textContent;
            button.textContent = 'Cancelling...';
            button.disabled = true;

            fetch(`/admin/users/${userId}/subscriptions/${subscriptionId}/cancel`, {
              method: 'POST',
              headers: {
                'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
              }
            })
            .then(response => response.json())
            .then(data => {
              if (data.success) {
                alert('Subscription cancelled successfully!');
                window.location.reload();
              } else {
                throw new Error(data.error || 'Failed to cancel subscription');
              }
            })
            .catch(error => {
              alert('Error: ' + error.message);
            })
            .finally(() => {
              button.textContent = originalText;
              button.disabled = false;
            });
          }
        }
      });
    }
  })();
</script>

<style>
  .admin-container {
    display: flex;
    justify-content: center;
    min-height: calc(100vh - 208.67px);
  }

  .admin-content {
    margin-left: 0;
    max-width: 1400px;
    padding: 2rem;
    width: 100%;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .admin-content h1 {
    color: #2c3e50;
    font-size: 1.75rem;
    margin: 0 0 0.5rem 0;
  }

  .users-stats {
    color: #7f8c8d;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
