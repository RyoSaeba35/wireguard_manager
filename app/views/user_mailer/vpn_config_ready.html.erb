<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    .cta-btn:hover {
      background-color: #e65c00;
    }
    .cta-btn-primary:hover {
      background-color: #c0392b;
    }
  </style>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #2c3e50; margin: 0; padding: 0;">
  <!-- Outer table with fixed width -->
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" style="max-width: 600px; margin: 0 auto;">
    <tr>
      <td style="padding: 20px;">
        <!-- Logo -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 0 auto; text-align: center; width: 100%;">
          <tr>
            <td style="padding: 10px 0; text-align: center;">
              <a href="https://www.vulcainvpn.com" style="display: inline-block;">
                <% if attachments['Vulcain_VPN_logo_3.png'] %>
                  <%= image_tag(
                    attachments['Vulcain_VPN_logo_3.png'].url,
                    alt: "Vulcain VPN Logo",
                    style: "max-width: 200px; height: auto; display: block; margin: 0 auto; border: 0;"
                  ) %>
                <% else %>
                  <span style="color: #2c3e50; font-weight: bold; font-size: 20px;">Vulcain VPN</span>
                <% end %>
              </a>
            </td>
          </tr>
        </table>

        <!-- Welcome Message -->
        <p style="font-size: 16px; margin: 20px 0 16px 0; text-align: left;">
          Hello <%= @user.email %>,
        </p>

        <!-- Success Message -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="width: 100%; background-color: #d4edda; border: 1px solid #c3e6cb; border-radius: 4px; margin: 20px 0;">
          <tr>
            <td style="padding: 15px; text-align: center;">
              <p style="margin: 0; font-size: 18px; color: #155724; font-weight: bold;">
                🎉 Your subscription is now active!
              </p>
            </td>
          </tr>
        </table>

        <!-- Main Message -->
        <p style="font-size: 16px; margin: 0 0 16px 0; text-align: left;">
          Thank you for subscribing to <strong>Vulcain VPN</strong>. Your subscription <strong>#<%= @subscription.name %></strong> is ready to use.
        </p>

        <p style="font-size: 16px; margin: 0 0 16px 0; text-align: left;">
          With Vulcain VPN, you can enjoy fast, secure, and private internet access with a French IP address.
        </p>

        <!-- Getting Started Section -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="width: 100%; background-color: #f8f9fa; border-radius: 4px; margin: 20px 0;">
          <tr>
            <td style="padding: 20px;">
              <p style="margin: 0 0 12px 0; font-size: 16px; font-weight: bold; color: #2c3e50;">
                Getting Started:
              </p>

              <p style="margin: 0 0 8px 0; font-size: 15px; color: #2c3e50;">
                <strong>1.</strong> Download and install the Vulcain VPN app on your device
              </p>

              <p style="margin: 0 0 8px 0; font-size: 15px; color: #2c3e50;">
                <strong>2.</strong> Log in with your account credentials
              </p>

              <p style="margin: 0; font-size: 15px; color: #2c3e50;">
                <strong>3.</strong> Connect and enjoy secure browsing!
              </p>
            </td>
          </tr>
        </table>

        <!-- CTA Buttons -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="width: 100%; margin: 20px 0;">
          <tr>
            <td style="text-align: center;">
              <!-- Primary CTA -->
              <a
                href="<%= user_subscription_url(@user, @subscription) %>"
                class="cta-btn cta-btn-primary"
                style="
                  background-color: #e74c3c;
                  color: white;
                  padding: 14px 28px;
                  border: none;
                  border-radius: 4px;
                  font-size: 16px;
                  text-decoration: none;
                  display: inline-block;
                  font-family: Arial, sans-serif;
                  font-weight: bold;
                "
              >
                Get Started Now
              </a>
            </td>
          </tr>
          <!-- Secondary Link -->
          <tr>
            <td style="text-align: center; padding-top: 15px;">
              <a
                href="https://www.vulcainvpn.com/download"
                style="color: #ff6e08; text-decoration: none; font-size: 14px;"
              >
                Download App →
              </a>
            </td>
          </tr>
        </table>

        <!-- Help Section -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="width: 100%; border-top: 1px solid #e0e0e0; margin: 30px 0 20px 0; padding-top: 20px;">
          <tr>
            <td>
              <p style="font-size: 15px; margin: 0 0 12px 0; text-align: left; color: #555;">
                <strong>Need help?</strong>
              </p>
              <p style="font-size: 15px; margin: 0; text-align: left; color: #555;">
                Check our
                <a href="https://www.vulcainvpn.com/setup" style="color: #ff6e08; text-decoration: none;">setup guide</a> or
                <a href="mailto:support@vulcainvpn.com" style="color: #ff6e08; text-decoration: none;">contact support</a>.
              </p>
            </td>
          </tr>
        </table>

        <!-- Regards -->
        <p style="font-size: 16px; margin: 20px 0 0 0; text-align: left;">
          Welcome to Vulcain VPN!<br>
          <strong>The Vulcain VPN Team</strong>
        </p>

        <!-- Footer -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="width: 100%; border-top: 1px solid #e0e0e0; margin-top: 30px; padding-top: 20px;">
          <tr>
            <td style="text-align: center;">
              <p style="font-size: 12px; color: #7f8c8d; margin: 0 0 8px 0;">
                © 2025 Vulcain VPN. All rights reserved.
              </p>
              <p style="font-size: 12px; margin: 0;">
                <a href="https://www.vulcainvpn.com/privacy" style="color: #7f8c8d; text-decoration: none;">Privacy Policy</a>
                <span style="color: #7f8c8d;"> • </span>
                <a href="https://www.vulcainvpn.com/terms" style="color: #7f8c8d; text-decoration: none;">Terms of Service</a>
                <span style="color: #7f8c8d;"> • </span>
                <a href="https://www.vulcainvpn.com/logging" style="color: #7f8c8d; text-decoration: none;">Logging Policy</a>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
