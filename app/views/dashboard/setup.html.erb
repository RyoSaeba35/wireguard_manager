<!-- app/views/dashboard/setup.html.erb -->
<div class="dashboard-container">
  <header class="dashboard-header">
    <h1>VPN Setup Guide</h1>
  </header>

  <section class="setup-guide-section">
    <h2>How to Set Up Your VPN</h2>
    <div class="alert alert-warning" style="margin-bottom: 1.5rem; padding: 1rem; background-color: #fff3cd; color: #856404; border-left: 4px solid #ffeeba;">
      <strong>Important Device Information:</strong>
      <ul style="margin-bottom: 0; padding-left: 1.2rem;">
        <li>Your subscription allows VPN connections on <strong>up to <%= @active_subscription&.max_devices || 3 %> devices</strong> simultaneously.</li>
        <li>Each device must be registered separately in the app.</li>
        <li>The VPN will automatically select the best server for you.</li>
      </ul>
    </div>
    <p>Follow these steps to connect to VulcainVPN:</p>

    <!-- Setup steps for VulcainVPN app -->
    <div class="setup-steps">
      <div class="step">
        <h3>1. Download VulcainVPN</h3>
        <p>Install the VulcainVPN app for your device:</p>
        <ul>
          <li><a href="#" target="_blank">iOS (App Store)</a> - Coming soon</li>
          <li><a href="#" target="_blank">Android (Google Play)</a> - Available now</li>
          <li><a href="#" target="_blank">Windows/macOS</a> - Coming soon</li>
        </ul>
        <p><em>Note: Currently available for Android only. iOS and desktop versions coming soon.</em></p>
      </div>

      <div class="step">
        <h3>2. Login to Your Account</h3>
        <p>Open the VulcainVPN app and login with your credentials:</p>
        <ul>
          <li><strong>Email:</strong> <%= current_user.email %></li>
          <li><strong>Password:</strong> Your VulcainVPN account password</li>
        </ul>
        <% unless @has_subscription %>
          <p class="alert alert-warning" style="padding: 0.5rem; margin: 0.5rem 0;">
            🔒 You need an active subscription to connect.
            <%= link_to "Subscribe now", new_user_subscription_path(current_user) %>
          </p>
        <% end %>
      </div>

      <div class="step">
        <h3>3. Register Your Device</h3>
        <p>The app will automatically register your device when you first login.</p>
        <ul>
          <li>Give your device a recognizable name (e.g., "My Phone", "Work Laptop")</li>
          <li>The device will be linked to your subscription</li>
          <li>You can manage devices from your dashboard</li>
        </ul>
      </div>

      <div class="step">
        <h3>4. Connect to VPN</h3>
        <p>Tap the <strong>Connect</strong> button in the app.</p>
        <ul>
          <li>The app will automatically select the best server for you</li>
          <li>Supports WireGuard, Hysteria2, and Shadowsocks protocols</li>
          <li>Connection typically takes 2-5 seconds</li>
        </ul>
        <p>Verify your connection at <a href="https://whatismyip.com" target="_blank">whatismyip.com</a>.</p>
      </div>

      <div class="step">
        <h3>5. Device Management</h3>
        <p>Your subscription includes up to <%= @active_subscription&.max_devices || 3 %> simultaneous connections:</p>
        <ul>
          <li>View active devices in your <%= link_to "dashboard", dashboard_path %></li>
          <li>Maximum <%= @active_subscription&.max_devices || 3 %> devices can be connected at once</li>
          <li>Disconnect from one device to free up a slot for another</li>
          <li>Devices are automatically disconnected after 5 minutes of inactivity</li>
        </ul>
      </div>

      <div class="step">
        <h3>6. Advanced: Manual WireGuard Setup (Optional)</h3>
        <p>If you prefer to use the standard WireGuard app instead of VulcainVPN:</p>
        <p class="alert alert-warning" style="padding: 0.5rem; margin: 0.5rem 0;">
          ⚠️ This feature is not available yet in the pooling architecture.
          Please use the VulcainVPN app for now.
        </p>
        <%# Future: Link to on-demand config generation when implemented %>
      </div>
    </div>
  </section>

  <!-- Protocol Information -->
  <section class="troubleshooting-section">
    <h2>Available Protocols</h2>

    <div class="faq-item">
      <button class="faq-question">
        WireGuard <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p><strong>Recommended for:</strong> General use, best balance of speed and security</p>
        <ul>
          <li>Modern, lightweight VPN protocol</li>
          <li>Excellent performance on all devices</li>
          <li>Low battery consumption on mobile</li>
          <li>Works on most networks</li>
        </ul>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-question">
        Hysteria2 <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p><strong>Recommended for:</strong> Restrictive networks, maximum speed</p>
        <ul>
          <li>Bypasses most network restrictions</li>
          <li>Very fast in high-latency conditions</li>
          <li>Good for streaming and gaming</li>
          <li>Built-in obfuscation (Salamander)</li>
        </ul>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-question">
        Shadowsocks <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p><strong>Recommended for:</strong> Censored regions, stealth connections</p>
        <ul>
          <li>Designed for bypassing censorship</li>
          <li>Looks like regular HTTPS traffic</li>
          <li>Works in China and other restricted countries</li>
          <li>AEAD encryption (2022-blake3-aes-256-gcm)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Troubleshooting section -->
  <section class="troubleshooting-section">
    <h2>Troubleshooting</h2>

    <div class="faq-item">
      <button class="faq-question">
        Can't Login to the App <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p><strong>Symptoms:</strong> "Invalid email or password" error</p>
        <ul>
          <li>Double-check your email and password</li>
          <li>Make sure your email is confirmed (check spam folder)</li>
          <li>Try <%= link_to "resetting your password", new_user_password_path %></li>
          <li>Contact support if issues persist</li>
        </ul>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-question">
        "No Active Subscription" Error <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p><strong>Symptoms:</strong> App says subscription expired or not found</p>
        <ul>
          <li>Check your subscription status in <%= link_to "dashboard", dashboard_path %></li>
          <li>Verify payment was successful in your email</li>
          <li>Try logging out and back in</li>
          <li><%= link_to "Renew subscription", new_user_subscription_path(current_user) %> if expired</li>
        </ul>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-question">
        "Maximum Devices Reached" Error <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p><strong>Symptoms:</strong> Can't connect because all device slots are in use</p>
        <ul>
          <li>You can have <%= @active_subscription&.max_devices || 3 %> devices connected simultaneously</li>
          <li>Disconnect from another device first</li>
          <li>Check your <%= link_to "dashboard", dashboard_path %> to see active devices</li>
          <li>Devices auto-disconnect after 5 minutes of inactivity</li>
        </ul>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-question">
        Connection Fails or Drops <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p><strong>Symptoms:</strong> VPN disconnects frequently or won't connect</p>
        <ul>
          <li>Check your internet connection</li>
          <li>Try switching protocols (WireGuard → Hysteria2 → Shadowsocks)</li>
          <li>Restart the app</li>
          <li>Restart your device</li>
          <li>Check for app updates</li>
          <li>Check firewall/antivirus settings</li>
        </ul>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-question">
        Slow Speeds <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p><strong>Symptoms:</strong> VPN is connected but internet is slow</p>
        <ul>
          <li>Test your base internet speed (disconnect VPN first)</li>
          <li>Try switching to Hysteria2 protocol (fastest)</li>
          <li>Close background apps consuming bandwidth</li>
          <li>Check server status in <%= link_to "dashboard", dashboard_path %></li>
          <li>Restart your router</li>
        </ul>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-question">
        Server Selection <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p><strong>How servers are selected:</strong></p>
        <ul>
          <li>The app automatically picks the best server based on:</li>
          <li>Your geographic location (closest server)</li>
          <li>Server load (least crowded)</li>
          <li>Server health (only healthy servers)</li>
          <li>You cannot manually choose servers (automatic only)</li>
        </ul>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-question">
        General Tips <span class="faq-icon">+</span>
      </button>
      <div class="faq-answer">
        <p>Keep your app updated and check for announcements. If issues persist, contact support at <a href="mailto:support@vulcainvpn.com">support@vulcainvpn.com</a>.</p>
      </div>
    </div>
  </section>
</div>

